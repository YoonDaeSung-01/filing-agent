# ── DART ─────────────────────────────────────────────────────────────────────
DART_API_KEY=          # opendart.fss.or.kr 에서 무료 발급 (필수)
# DART_REPORT_CODE=11011   # 11011=사업보고서, 11012=반기, 11013=1분기, 11014=3분기
# DART_FS_DIV=CFS          # CFS=연결, OFS=별도

# ── LLM (LiteLLM 게이트웨이) ─────────────────────────────────────────────────
LLM_API_KEY=           # OpenAI: sk-...  |  Anthropic: sk-ant-...  (필수)
# LLM_MODEL=gpt-4o-mini   # Anthropic: claude-haiku-4-5-20251001

# ── 임베딩 ────────────────────────────────────────────────────────────────────
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ── 벡터 DB (pgvector) ───────────────────────────────────────────────────────
# 포트 5433 사용(로컬 PostgreSQL이 5432를 선점하는 경우 충돌 회피). docker-compose와 일치.
# PG_DSN=postgresql://filing:filing@localhost:5433/filing_agent

# ── 검색·리랭킹 (Phase 2) ────────────────────────────────────────────────────
# RETRIEVE_TOP_N=20       # 벡터/BM25 후보 수
# FINAL_TOP_K=5           # 리랭킹 후 LLM에 넘길 청크 수
# HYBRID_ENABLED=true     # 벡터+BM25 RRF 융합
# RERANK_ENABLED=true     # BGE-reranker-v2-m3 cross-encoder
# RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── 관측 (Phase 6, 선택) ─────────────────────────────────────────────────────
# 키가 없으면 트레이싱은 비활성(앱·테스트는 정상 동작). 키는 cloud.langfuse.com 에서 발급.
# LANGFUSE_PUBLIC_KEY=    # pk-lf-...
# LANGFUSE_SECRET_KEY=    # sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ═════════════════════════════════════════════════════════════════════════════
# 플랫폼 확장 (주식 정보·모의투자) — docs/platform_apply_plan.md
# ═════════════════════════════════════════════════════════════════════════════

# ── 한투 KIS (모의투자 vps) ──────────────────────────────────────────────────
# apiportal.koreainvestment.com 에서 발급. ★모의투자(vps)용 키만★ 사용(실전 아님).
KIS_APP_KEY=            # 모의투자용 APP Key
KIS_APP_SECRET=         # 모의투자용 APP Secret (🔐 비밀번호급 — 커밋·로깅 절대 금지)
KIS_ACCOUNT_NO=        # 모의계좌번호 8자리(상품코드 제외)
# KIS_BASE_URL=https://openapivts.koreainvestment.com:29443   # vps(모의) 도메인. 실전과 다름

# ── 인증 (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=            # 임의의 긴 랜덤 문자열 (🔐 커밋 금지). 예: openssl rand -hex 32
# JWT_EXPIRE_MIN=60

# ── 뉴스 (네이버 검색 API) ──────────────────────────────────────────────────
# developers.naver.com 에서 검색 API 신청 후 발급.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
