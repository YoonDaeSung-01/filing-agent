# ── DART ─────────────────────────────────────────────────────────────────────
DART_API_KEY=          # opendart.fss.or.kr 에서 무료 발급 (필수)
# DART_REPORT_CODE=11011   # 11011=사업보고서, 11012=반기, 11013=1분기, 11014=3분기
# DART_FS_DIV=CFS          # CFS=연결, OFS=별도

# ── LLM (LiteLLM 게이트웨이) ─────────────────────────────────────────────────
LLM_API_KEY=           # OpenAI: sk-...  |  Anthropic: sk-ant-...  (필수)
# LLM_MODEL=gpt-4o-mini   # Anthropic: claude-haiku-4-5-20251001

# ── 임베딩 ────────────────────────────────────────────────────────────────────
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ── 벡터 DB (pgvector) ───────────────────────────────────────────────────────
# 포트 5433 사용(로컬 PostgreSQL이 5432를 선점하는 경우 충돌 회피). docker-compose와 일치.
# PG_DSN=postgresql://filing:filing@localhost:5433/filing_agent

# ── 검색·리랭킹 (Phase 2) ────────────────────────────────────────────────────
# RETRIEVE_TOP_N=20       # 벡터/BM25 후보 수
# FINAL_TOP_K=5           # 리랭킹 후 LLM에 넘길 청크 수
# HYBRID_ENABLED=true     # 벡터+BM25 RRF 융합
# RERANK_ENABLED=true     # BGE-reranker-v2-m3 cross-encoder
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
